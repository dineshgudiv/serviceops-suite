# Public browser origin for the deployed frontend.
NEXT_PUBLIC_APP_URL=https://your-frontend.vercel.app

# External backend base URL that serves /api/auth, /api/itsm, /api/cmdb, etc.
# For local development this can stay on the Docker gateway.
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8080

# Optional server-only override. Use this on Vercel if the server runtime should call
# a different external base URL than the browser-exposed one above.
GATEWAY_INTERNAL_URL=https://api.your-company.example

# Optional environment label for UI/debug use.
NEXT_PUBLIC_ENV=dev
